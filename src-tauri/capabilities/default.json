  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "sql:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "fera-crawler",
          "cmd": "",
          "args": true
        }
      ]
    }
  ]
}
