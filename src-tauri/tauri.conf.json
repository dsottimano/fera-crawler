{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "Fera",
  "version": "0.1.0",
  "identifier": "com.fera.crawler",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev --workspace=frontend",
    "beforeBuildCommand": "npm run build --workspace=frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Fera — SEO Crawler",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/fera-crawler"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "installMode": "perUser"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:fera.db"]
    }
  }
}
